{
  "appId": "com.astrocurrents.app",
  "appName": "AstroAtlas",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor",
    "allowNavigation": [
      "*.googleapis.com",
      "*.firebaseio.com",
      "*.firebase.google.com",
      "*.gstatic.com",
      "*.openai.com",
      "*.anthropic.com"
    ]
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#02020F",
      "showSpinner": false,
      "launchAutoHide": true,
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#07092a"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK"
    }
  }
}